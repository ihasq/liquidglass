{
  "entries": ["assembly-quad/index.ts"],
  "targets": {
    "debug": {
      "outFile": "build/debug-quad.wasm",
      "textFile": "build/debug-quad.wat",
      "sourceMap": true,
      "debug": true,
      "enable": ["simd"]
    },
    "release": {
      "outFile": "build/release-quad.wasm",
      "textFile": "build/release-quad.wat",
      "sourceMap": true,
      "optimizeLevel": 3,
      "shrinkLevel": 0,
      "converge": false,
      "noAssert": false,
      "enable": ["simd"]
    }
  },
  "options": {
    "bindings": "esm"
  }
}
