{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/liquidglass.ts!",
    "src/index.ts!",
    "src/core/specular/specular-worklet.js!",
    "demo/**/*.html",
    "demo/parameter-lab/main.tsx",
    "demo/parameter-lab/recorder-worker.js",
    "test/integrity/index.mjs",
    "test/cdp-*.mjs",
    "test/e2e/runner.mjs",
    "test/e2e/run-tests.js",
    "test/e2e/test-page.html",
    "test/integrity/smt/*.mjs",
    "scripts/**/*.{js,mjs,ts}",
    "vite.config.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx,js}",
    "demo/**/*.{ts,tsx,js}",
    "test/**/*.{mjs,js,ts}"
  ],
  "ignore": [
    "src/shaders/wasm/**"
  ],
  "ignoreDependencies": [
    "@webgpu/types"
  ]
}
