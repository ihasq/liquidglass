/**
 * Quadrant displacement computation (Pass 1) - LUT-based
 *
 * Computes displacement for the BOTTOM-RIGHT quadrant only.
 * The quadrant is symmetric, so other quadrants are derived by mirroring.
 *
 * Uses pre-computed LUTs for profile functions instead of runtime exp().
 * Profile selection: 0=exponential, 1=squircle, 2=circle, 3=parabolic, 4=cosine, 5=linear
 *
 * RGB encoding:
 * - R channel: X displacement (128 = none, <128 = left, >128 = right)
 * - G channel: Y displacement (128 = none, <128 = up, >128 = down)
 * - B channel: unused (128)
 * - A channel: 255
 */

struct Uniforms {
    u_quadResolution: vec2<f32>,
    u_fullResolution: vec2<f32>,
    u_borderRadius: f32,
    u_edgeWidthRatio: f32,
    u_profile: u32,  // 0=exponential, 1=squircle, 2=circle, 3=parabolic, 4=cosine, 5=linear
    _pad: u32,       // alignment padding
}

@group(0) @binding(0)
var<uniform> uniforms: Uniforms;

