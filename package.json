{
  "name": "liquidglass.css",
  "version": "0.0.16",
  "description": "Physics-based liquid glass refraction effect using CSS and SVG filters",
  "type": "module",
  "main": "dist/liquidglass.js",
  "module": "dist/liquidglass.js",
  "types": "dist/liquidglass.d.ts",
  "exports": {
    ".": {
      "types": "./dist/liquidglass.d.ts",
      "import": "./dist/liquidglass.js",
      "default": "./dist/liquidglass.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "default": "./dist/schema.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.js",
      "default": "./dist/env.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-displacement-luts.mjs",
    "build": "tsc && vite build",
    "generate-luts": "node scripts/generate-displacement-luts.mjs",
    "build:site": "npm run build && cd site && npm install && npm run build",
    "preview": "vite preview",
    "test": "node test/integrity/index.mjs",
    "test:types": "node test/integrity/index.mjs --only=types",
    "test:build": "node test/integrity/index.mjs --only=build",
    "test:smt": "node test/integrity/index.mjs --only=smt",
    "test:e2e": "npx serve test -l 3333 --no-clipboard",
    "test:e2e:headed": "node test/e2e/runner.mjs --headed",
    "test:e2e:verbose": "node test/e2e/runner.mjs --verbose",
    "asbuild": "npm run asbuild:debug && npm run asbuild:release",
    "asbuild:debug": "asc src/shaders/wasm/index.ts --target debug",
    "asbuild:release": "asc src/shaders/wasm/index.ts --target release",
    "start": "npx serve ."
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@webgpu/types": "^0.1.69",
    "assemblyscript": "^0.28.14",
    "preact": "^10.29.1",
    "puppeteer": "^22.15.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.8.0",
    "vite-plugin-glsl": "^1.6.0",
    "z3-solver": "^4.16.0"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "keywords": [
    "liquid-glass",
    "glass-effect",
    "refraction",
    "svg-filter",
    "backdrop-filter",
    "css"
  ],
  "license": "MIT"
}
