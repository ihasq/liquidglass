{
  "name": "liquidglass.css",
  "version": "0.0.7",
  "description": "Physics-based liquid glass refraction effect using CSS and SVG filters",
  "type": "module",
  "main": "dist/liquidglass.js",
  "module": "dist/liquidglass.js",
  "types": "dist/liquidglass.d.ts",
  "exports": {
    ".": "./dist/liquidglass.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run shaders && tsc && vite build",
    "shaders": "node scripts/transpile-shaders.mjs",
    "preview": "vite preview",
    "test:e2e": "node --experimental-vm-modules test/e2e/run-tests.js",
    "test:e2e:update": "node --experimental-vm-modules test/e2e/run-tests.js --update-snapshots",
    "asbuild": "npm run asbuild:debug && npm run asbuild:release",
    "asbuild:debug": "asc src/shaders/wasm-simd/index.ts --target debug",
    "asbuild:release": "asc src/shaders/wasm-simd/index.ts --target release",
    "test": "node --test",
    "start": "npx serve ."
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.69",
    "assemblyscript": "^0.28.14",
    "naga-wasi-cli": "^0.1.0",
    "pako": "^2.1.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "puppeteer": "^22.0.0",
    "serve-handler": "^6.1.7",
    "sharp": "^0.34.5",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.8.0",
    "z3-solver": "^4.16.0"
  },
  "keywords": [
    "liquid-glass",
    "glass-effect",
    "refraction",
    "svg-filter",
    "backdrop-filter",
    "css"
  ],
  "license": "MIT",
  "dependencies": {
    "canvas": "^3.2.3"
  }
}
